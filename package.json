{
  "name": "@kiket-dev/sdk",
  "version": "0.1.0",
  "description": "Official TypeScript/Node.js SDK for building Kiket extensions",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "kiket",
    "extensions",
    "webhooks",
    "workflow",
    "automation"
  ],
  "author": "Kiket Team <team@kiket.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kiket-dev/kiket.git",
    "directory": "sdk/nodejs"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "axios": "^1.17.0",
    "express": "^5.2.1",
    "jose": "^6.2.3",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.2",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint": "^10.4.1",
    "jest": "^30.4.2",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3"
  }
}
